<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="YOLOv8 NCNN 检测器"
            android:textColor="#FFFFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- ═══ 权限 ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="权限管理"
            android:textColor="#FF00BCD4"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
            <Button android:id="@+id/btn_grant_overlay" android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:text="悬浮窗" android:textSize="12sp" android:textAllCaps="false" />
            <TextView android:id="@+id/tv_overlay_status" android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="检查中..." android:textSize="12sp" android:gravity="center" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
            <Button android:id="@+id/btn_grant_accessibility" android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:text="无障碍服务" android:textSize="12sp" android:textAllCaps="false" />
            <TextView android:id="@+id/tv_accessibility_status" android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="检查中..." android:textSize="12sp" android:gravity="center" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
            <Button android:id="@+id/btn_grant_storage" android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:text="存储权限" android:textSize="12sp" android:textAllCaps="false" />
            <TextView android:id="@+id/tv_storage_status" android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="检查中..." android:textSize="12sp" android:gravity="center" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="12dp">
            <Button android:id="@+id/btn_grant_notification" android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:text="通知权限" android:textSize="12sp" android:textAllCaps="false" />
            <TextView android:id="@+id/tv_notification_status" android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="检查中..." android:textSize="12sp" android:gravity="center" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" />

        <!-- ═══ 模型 ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="模型设置"
            android:textColor="#FF00BCD4"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
            <Button android:id="@+id/btn_select_param" android:layout_width="wrap_content" android:layout_height="40dp"
                android:text="选择 .param" android:textSize="12sp" android:textAllCaps="false" />
            <TextView android:id="@+id/tv_param_path" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="未选择" android:textColor="#AAFFFFFF" android:textSize="12sp"
                android:paddingStart="8dp" android:singleLine="true" android:ellipsize="middle" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="8dp">
            <Button android:id="@+id/btn_select_bin" android:layout_width="wrap_content" android:layout_height="40dp"
                android:text="选择 .bin" android:textSize="12sp" android:textAllCaps="false" />
            <TextView android:id="@+id/tv_bin_path" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="未选择" android:textColor="#AAFFFFFF" android:textSize="12sp"
                android:paddingStart="8dp" android:singleLine="true" android:ellipsize="middle" />
        </LinearLayout>

        <Button android:id="@+id/btn_load_model" android:layout_width="match_parent" android:layout_height="48dp"
            android:text="加载模型" android:textAllCaps="false" android:backgroundTint="#FF2196F3" />

        <TextView android:id="@+id/tv_model_status" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="模型: 未加载" android:textColor="#FFFFC107" android:textSize="14sp" android:gravity="center"
            android:paddingTop="4dp" android:paddingBottom="12dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" />

        <!-- ═══ 推理设置 ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="推理设置"
            android:textColor="#FF00BCD4"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="置信度:" android:textColor="#DDFFFFFF" android:textSize="13sp" />
            <SeekBar android:id="@+id/seek_conf_thresh" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" />
            <TextView android:id="@+id/tv_conf_value" android:layout_width="50dp" android:layout_height="wrap_content"
                android:text="0.35" android:textColor="#FFFFFFFF" android:textSize="13sp" android:gravity="center" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="NMS阈值:" android:textColor="#DDFFFFFF" android:textSize="13sp" />
            <SeekBar android:id="@+id/seek_nms_thresh" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" />
            <TextView android:id="@+id/tv_nms_value" android:layout_width="50dp" android:layout_height="wrap_content"
                android:text="0.45" android:textColor="#FFFFFFFF" android:textSize="13sp" android:gravity="center" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="捕获缩放:" android:textColor="#DDFFFFFF" android:textSize="13sp" />
            <SeekBar android:id="@+id/seek_capture_scale" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" />
            <TextView android:id="@+id/tv_capture_scale_value" android:layout_width="50dp" android:layout_height="wrap_content"
                android:text="50%" android:textColor="#FFFFFFFF" android:textSize="13sp" android:gravity="center" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="8dp">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="输入尺寸:" android:textColor="#DDFFFFFF" android:textSize="13sp" />
            <Spinner android:id="@+id/spinner_target_size" android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="4dp">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="线程数:" android:textColor="#DDFFFFFF" android:textSize="13sp" />
            <Spinner android:id="@+id/spinner_threads" android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" />
        </LinearLayout>

        <CheckBox android:id="@+id/cb_use_gpu" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="使用 GPU (Vulkan)" android:textColor="#DDFFFFFF" android:textSize="13sp" android:paddingTop="4dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF"
            android:layout_marginTop="12dp" />

        <!-- ═══ 截图模式 ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="截图模式"
            android:textColor="#FF00BCD4"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="8dp" />

        <RadioGroup
            android:id="@+id/rg_capture_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <RadioButton
                android:id="@+id/rb_media_projection"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MediaProjection"
                android:textColor="#DDFFFFFF"
                android:textSize="12sp"
                android:checked="true" />
            <RadioButton
                android:id="@+id/rb_root"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Root 截图"
                android:textColor="#DDFFFFFF"
                android:textSize="12sp" />
        </RadioGroup>

        <TextView
            android:id="@+id/tv_root_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Root: 检测中..."
            android:textColor="#88FFFFFF"
            android:textSize="12sp"
            android:paddingBottom="12dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" />

        <!-- ═══ 自动点击 ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="自动点击"
            android:textColor="#FF00BCD4"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="目标标签:" android:textColor="#DDFFFFFF" android:textSize="13sp" />
            <EditText android:id="@+id/et_target_label" android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:hint="-1 = 全部" android:textColor="#FFFFFFFF"
                android:textColorHint="#55FFFFFF" android:textSize="13sp" android:inputType="numberSigned"
                android:background="#33FFFFFF" android:paddingStart="8dp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="8dp">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="点击间隔(ms):" android:textColor="#DDFFFFFF" android:textSize="13sp" />
            <EditText android:id="@+id/et_click_delay" android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:hint="500" android:textColor="#FFFFFFFF"
                android:textColorHint="#55FFFFFF" android:textSize="13sp" android:inputType="number"
                android:background="#33FFFFFF" android:paddingStart="8dp" />
        </LinearLayout>

        <Button android:id="@+id/btn_save_settings" android:layout_width="match_parent" android:layout_height="40dp"
            android:text="保存设置" android:textAllCaps="false" android:backgroundTint="#FF607D8B" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF"
            android:layout_marginTop="12dp" />

        <!-- ═══ 操作 ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="操作"
            android:textColor="#FF00BCD4"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="8dp" />

        <Button android:id="@+id/btn_start_overlay" android:layout_width="match_parent" android:layout_height="48dp"
            android:text="启动悬浮窗" android:textAllCaps="false" android:backgroundTint="#FF9C27B0" />

        <Button android:id="@+id/btn_start_capture" android:layout_width="match_parent" android:layout_height="48dp"
            android:text="开始屏幕捕获" android:textAllCaps="false" android:backgroundTint="#FF4CAF50"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="提示: 先启动悬浮窗，再开始屏幕捕获。\n使用悬浮面板控制检测和设置点击坐标。"
            android:textColor="#88FFFFFF"
            android:textSize="11sp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp" />

    </LinearLayout>
</ScrollView>
